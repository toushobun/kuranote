# Local Supabase stack example
# Uncomment this block when using local Supabase.
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-local-publishable-or-anon-key

# Supabase Cloud dev / staging example
# Uncomment this block when using Supabase Cloud dev / staging.
# Do not use production values for local development.
# NEXT_PUBLIC_SUPABASE_URL=https://your-dev-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-dev-or-staging-publishable-or-anon-key
